<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_title"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/home_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <ProgressBar
        android:id="@+id/progressCenters"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="22dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvCentersError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_surface_card"
        android:padding="14dp"
        android:text="Failed to load centers."
        android:textColor="@color/danger"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnCentersRetry"
        android:layout_width="130dp"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_secondary_button"
        android:text="@string/retry"
        android:textAllCaps="false"
        android:textColor="@color/brand_primary"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCenters"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_surface_card"
        android:clipToPadding="false"
        android:padding="10dp"
        android:layout_weight="1" />

</LinearLayout>