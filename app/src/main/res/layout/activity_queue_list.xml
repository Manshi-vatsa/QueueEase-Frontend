<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvCenterTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/queue_live_title"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_hero_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Smart Queue Command Center"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLiveSync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_live_strip"
            android:padding="8dp"
            android:text="Live sync active • Last update: --:--"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_metric_tile"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Crowd Pressure"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvCrowdPressureValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Low"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_metric_tile"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Best Join Window"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvBestJoinWindow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Now"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_surface_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvCurrentServing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current serving: -"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMyQueueNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Your queue number: -"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvPeopleAhead"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="People ahead: -"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvWaitTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Estimated wait: -"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvRecommendation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_chip"
            android:padding="8dp"
            android:text="Recommendation: -"
            android:textColor="@color/brand_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btnJoinQueue"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_primary_button"
        android:text="@string/join_queue"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnServeNext"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_primary_button"
        android:text="Serve Next"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvTurnStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_chip"
        android:padding="8dp"
        android:text="Your turn in ~- min"
        android:textColor="@color/brand_primary"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/progressQueueUrgency"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/tvAdminStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_surface_card"
        android:padding="12dp"
        android:text="Served today: 0 | Avg wait: 0 min"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/layoutSimulation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_surface_card"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Digital Twin Simulation"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSimulationRates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Arrival rate: - | Service rate: -"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvPredictions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Current: - | 15m: - | 30m: - | 60m: -"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvSuggestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_chip"
            android:padding="8dp"
            android:text="Suggestion: -"
            android:textColor="@color/brand_primary"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressCrowdLevel"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/tvCrowdLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Crowd level: Low"
            android:textColor="@color/success"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvQueueGraph"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Queue graph loading..."
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutWhatIf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_surface_card"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Admin What-If Analysis"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAddStaffScenario"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:text="+1 Staff"
                android:textAllCaps="false"
                android:textColor="@color/brand_primary" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnFasterServiceScenario"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:text="+25% Speed"
                android:textAllCaps="false"
                android:textColor="@color/brand_primary" />
        </LinearLayout>

        <Button
            android:id="@+id/btnResetScenario"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_secondary_button"
            android:text="Reset Scenario"
            android:textAllCaps="false"
            android:textColor="@color/brand_primary" />

        <TextView
            android:id="@+id/tvWhatIfImpact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Impact: Baseline mode"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressQueue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvQueueError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_surface_card"
        android:padding="12dp"
        android:text="Failed to load queue."
        android:textColor="@color/danger"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnQueueRetry"
        android:layout_width="120dp"
        android:layout_height="46dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_secondary_button"
        android:text="@string/retry"
        android:textAllCaps="false"
        android:textColor="@color/brand_primary"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvQueueEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_surface_card"
        android:padding="12dp"
        android:text="Queue is empty."
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Live Queue Feed"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewQueue"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_surface_card"
        android:clipToPadding="false"
        android:padding="10dp"
        android:layout_weight="1" />

</LinearLayout>