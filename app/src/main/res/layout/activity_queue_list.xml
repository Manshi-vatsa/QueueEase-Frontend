<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvCenterTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/queue_live_title"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_surface_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvCurrentServing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current serving: -"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMyQueueNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Your queue number: -"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvPeopleAhead"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="People ahead: -"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvWaitTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Estimated wait: -"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvRecommendation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_chip"
            android:padding="8dp"
            android:text="Recommendation: -"
            android:textColor="@color/brand_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btnJoinQueue"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_primary_button"
        android:text="@string/join_queue"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/progressQueue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvQueueError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_surface_card"
        android:padding="12dp"
        android:text="Failed to load queue."
        android:textColor="@color/danger"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnQueueRetry"
        android:layout_width="120dp"
        android:layout_height="46dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_secondary_button"
        android:text="@string/retry"
        android:textAllCaps="false"
        android:textColor="@color/brand_primary"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvQueueEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_surface_card"
        android:padding="12dp"
        android:text="Queue is empty."
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewQueue"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_surface_card"
        android:clipToPadding="false"
        android:padding="10dp"
        android:layout_weight="1" />

</LinearLayout>